{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "NutriTrack AI Design Tokens — exported for cross-platform use (web, mobile, future clients). These mirror the Tailwind config and CSS custom properties in globals.css.",
  "$version": "1.0.0",

  "color": {
    "background": {
      "light": "#F8FAFC",
      "dark": "#0D1221",
      "$description": "60% — page background"
    },
    "foreground": {
      "light": "#0F172A",
      "dark": "#F8FAFC",
      "$description": "Primary text color"
    },
    "surface": {
      "light": "#FFFFFF",
      "dark": "#111827",
      "$description": "30% — card and panel surfaces"
    },
    "surface-raised": {
      "light": "#F1F5F9",
      "dark": "#1E2A3D",
      "$description": "Slightly elevated surface (hover states, nested cards)"
    },
    "muted": {
      "light": "#F1F5F9",
      "dark": "#1E2A3D"
    },
    "muted-foreground": {
      "light": "#64748B",
      "dark": "#7A8FA6",
      "$description": "Secondary / supporting text"
    },
    "border": {
      "light": "#E2E8F0",
      "dark": "#1E2D45",
      "$description": "Dividers, card borders, input borders"
    },
    "accent": {
      "light": "#2563EB",
      "dark": "#3B82F6",
      "$description": "10% — primary action, links, highlights. BLUE ONLY."
    },
    "accent-subtle": {
      "light": "#EFF6FF",
      "dark": "rgba(59,130,246,0.12)",
      "$description": "Background tint for accent elements"
    },
    "success": {
      "default": "#22C55E",
      "subtle-light": "#F0FDF4",
      "subtle-dark": "rgba(34,197,94,0.12)"
    },
    "warning": {
      "default": "#F59E0B",
      "subtle-light": "#FFFBEB",
      "subtle-dark": "rgba(245,158,11,0.12)"
    },
    "danger": {
      "default": "#EF4444",
      "subtle-light": "#FEF2F2",
      "subtle-dark": "rgba(239,68,68,0.12)"
    },
    "sidebar": {
      "background-light": "#FFFFFF",
      "background-dark": "#0A111E",
      "border-light": "#E2E8F0",
      "border-dark": "#1E2D45"
    },
    "macro": {
      "protein": "#2563EB",
      "carbs": "#22C55E",
      "fat": "#F59E0B",
      "fiber": "#64748B",
      "$description": "Fixed colors for macro nutrient visualization — do NOT change without updating all charts"
    },
    "chart": {
      "1": "#2563EB",
      "2": "#22C55E",
      "3": "#F59E0B",
      "4": "#EF4444",
      "5": "#64748B"
    },
    "forbidden": ["purple", "pink", "any neon or rainbow gradient"],
    "$note": "The 60-30-10 color rule: background=60%, surfaces/cards=30%, accent(blue)=10%. Never use purple, pink, or neon colors."
  },

  "typography": {
    "fontFamily": {
      "sans": "Inter, system-ui, sans-serif",
      "mono": "Geist Mono, ui-monospace, monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px",
      "4xl": "36px",
      "5xl": "48px"
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.75
    }
  },

  "spacing": {
    "$description": "8px grid system. All spacing values are multiples of 4px (half-grid) or 8px (full grid).",
    "unit": "8px",
    "scale": {
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px",
      "24": "96px"
    }
  },

  "borderRadius": {
    "sm": "4px",
    "DEFAULT": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "24px",
    "full": "9999px"
  },

  "shadow": {
    "card": "0 0 0 1px #E2E8F0, 0 2px 8px -2px rgba(0,0,0,0.06)",
    "card-hover": "0 0 0 1px #E2E8F0, 0 8px 24px -4px rgba(0,0,0,0.10)",
    "sm": "0 1px 3px 0 rgba(0,0,0,0.07)",
    "md": "0 4px 12px -2px rgba(0,0,0,0.08)",
    "lg": "0 8px 24px -4px rgba(0,0,0,0.08)"
  },

  "animation": {
    "$description": "Max 200ms. Framer Motion for page transitions. Skeleton loaders instead of spinners. No decorative animations.",
    "duration": {
      "fast": "100ms",
      "default": "150ms",
      "slow": "200ms"
    },
    "easing": {
      "default": "cubic-bezier(0.16, 1, 0.3, 1)",
      "in-out": "cubic-bezier(0.65, 0, 0.35, 1)"
    }
  },

  "breakpoints": {
    "xs": "375px",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1400px"
  }
}
