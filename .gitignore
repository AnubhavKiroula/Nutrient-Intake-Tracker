# ============================================================
# NutriTrack AI — Monorepo .gitignore
# ============================================================

# ── Node / pnpm ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnpm-store/

# ── Next.js ──────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/

# ── Environment variables (NEVER commit secrets) ──────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
frontend/.env*.local
backend/.env
backend/.env.local

# ── Python / Backend (Phase 2+) ──────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/.venv/
backend/env/
backend/build/
backend/dist/
backend/*.egg-info/
backend/.eggs/
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
*.pyc

# ── Database (Phase 3+) ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ── Storybook ────────────────────────────────────────────────
storybook-static/

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
*.suo
*.user

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Misc ─────────────────────────────────────────────────────
.cache/
.turbo/
*.tsbuildinfo
